# Node modules (ignore in all packages)
**/node_modules/

# Next.js build output
.next/
out/

# Production build folders
dist/
build/

# Local environment files
.env
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Test coverage
coverage/
*.lcov

# TypeScript
*.tsbuildinfo

# Parcel, cache and other caches
.cache/
.parcel-cache/
.turbo/

# Vercel
.vercel/
.vercel/output/

# Serverless
.serverless/

# Misc
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.iml

# Editor temporary files
*.swp
*~

# Mac files
.Spotlight-V100
.Trashes

# Yarn / npm / pnpm lockfiles are typically committed; do not ignore them unless intentional

# Optional: ignore local build artifacts for individual packages
**/.next/
**/out/
**/dist/
**/build/

# Ignore local dotenv files but keep examples
.env.local
.env.development.local
.env.test.local
.env.production.local

